<%- include('../partials/header', { pageTitle: '新建文档' }) %>

<!-- Quill CSS -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">

<div class="max-w-4xl mx-auto fade-in">
  <div class="flex items-center gap-3 mb-6">
    <a href="/documents" class="text-gray-400 hover:text-gray-600 transition">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <h1 class="text-2xl font-bold text-gray-800">新建文档</h1>
  </div>

  <div class="bg-white rounded-2xl shadow-sm p-6">
    <form id="docForm" action="/documents" method="POST" class="space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">文档标题</label>
        <input type="text" name="title" required placeholder="请输入文档标题"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition text-lg font-medium">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">文档内容</label>
        <!-- Upload buttons -->
        <div class="flex gap-2 mb-2">
          <label class="cursor-pointer bg-blue-50 text-blue-600 border border-blue-200 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-100 transition flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            上传图片
            <input type="file" accept="image/*" class="hidden" onchange="uploadImage(this)">
          </label>
          <label class="cursor-pointer bg-green-50 text-green-600 border border-green-200 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-green-100 transition flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            上传视频
            <input type="file" accept="video/*" class="hidden" onchange="uploadVideo(this)">
          </label>
        </div>
        <div id="editor" style="min-height: 300px;"></div>
        <input type="hidden" name="content" id="content">
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit"
          class="bg-gradient-to-r from-purple-600 to-blue-500 text-white px-6 py-2.5 rounded-xl font-semibold hover:shadow-lg hover:scale-[1.02] transition-all duration-200">
          保存文档
        </button>
        <a href="/documents"
          class="bg-gray-100 text-gray-600 px-6 py-2.5 rounded-xl font-semibold hover:bg-gray-200 transition">
          取消
        </a>
      </div>
    </form>
  </div>
</div>

<!-- Quill JS -->
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: '请输入文档内容...',
    modules: {
      toolbar: [
        [{ header: [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        [{ color: [] }, { background: [] }],
        ['link', 'blockquote', 'code-block'],
        ['clean']
      ]
    }
  });

  document.getElementById('docForm').addEventListener('submit', function () {
    document.getElementById('content').value = quill.root.innerHTML;
  });

  function uploadImage(input) {
    const file = input.files[0];
    if (!file) return;
    const fd = new FormData();
    fd.append('image', file);
    fetch('/documents/upload/image', { method: 'POST', body: fd })
      .then(r => r.json())
      .then(data => {
        if (data.url) {
          const range = quill.getSelection(true);
          quill.insertEmbed(range.index, 'image', data.url);
        }
      });
  }

  function uploadVideo(input) {
    const file = input.files[0];
    if (!file) return;
    const fd = new FormData();
    fd.append('video', file);
    fetch('/documents/upload/video', { method: 'POST', body: fd })
      .then(r => r.json())
      .then(data => {
        if (data.url) {
          const range = quill.getSelection(true);
          const index = range ? range.index : quill.getLength();
          quill.insertEmbed(index, 'video', data.url);
        }
      });
  }
</script>

<%- include('../partials/footer') %>
