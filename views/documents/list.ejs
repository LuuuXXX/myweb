<%- include('../partials/header', { pageTitle: '我的文档' }) %>

<div class="fade-in">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">我的文档</h1>
      <p class="text-gray-500 text-sm mt-1">共 <%= docs.length %> 篇文档</p>
    </div>
    <a href="/documents/new"
      class="bg-gradient-to-r from-purple-600 to-blue-500 text-white px-5 py-2.5 rounded-xl font-semibold hover:shadow-lg hover:scale-105 transition-all duration-200 flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      新建文档
    </a>
  </div>

  <% if (docs.length === 0) { %>
  <div class="text-center py-20">
    <div class="w-20 h-20 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
    </div>
    <h3 class="text-lg font-semibold text-gray-600 mb-2">暂无文档</h3>
    <p class="text-gray-400 text-sm mb-6">点击"新建文档"开始创建您的第一篇文档吧</p>
    <a href="/documents/new"
      class="bg-gradient-to-r from-purple-600 to-blue-500 text-white px-6 py-2.5 rounded-xl font-semibold hover:shadow-lg transition-all duration-200 inline-block">
      新建文档
    </a>
  </div>
  <% } else { %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    <% docs.forEach(doc => { %>
    <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-200 p-5 flex flex-col">
      <div class="flex-1">
        <h2 class="text-base font-semibold text-gray-800 mb-2 line-clamp-2">
          <a href="/documents/<%= doc.id %>" class="hover:text-purple-600 transition">
            <%= doc.title %>
          </a>
        </h2>
        <p class="text-gray-400 text-xs">
          更新于 <%= new Date(doc.updated_at).toLocaleDateString('zh-CN') %>
        </p>
      </div>
      <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gray-100">
        <a href="/documents/<%= doc.id %>"
          class="flex-1 text-center text-sm text-purple-600 font-medium hover:bg-purple-50 py-1.5 rounded-lg transition">
          查看
        </a>
        <a href="/documents/<%= doc.id %>/edit"
          class="flex-1 text-center text-sm text-blue-600 font-medium hover:bg-blue-50 py-1.5 rounded-lg transition">
          编辑
        </a>
        <form action="/documents/<%= doc.id %>/delete" method="POST" class="flex-1"
          onsubmit="return confirm('确定要删除这篇文档吗？')">
          <button type="submit"
            class="w-full text-sm text-red-500 font-medium hover:bg-red-50 py-1.5 rounded-lg transition">
            删除
          </button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
